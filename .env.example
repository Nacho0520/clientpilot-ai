# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Vercel Cron: GET /api/cron/followups exige Authorization: Bearer <este valor>
CRON_SECRET=

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Anthropic ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- Twilio WhatsApp ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ---- Meta Cloud API (opcional; alternativa a Twilio) ----
META_SYSTEM_USER_TOKEN=
META_VERIFY_TOKEN=
# App Secret de Meta → firma X-Hub-Signature-256 en POST /api/meta/webhook (obligatorio en producción si usas Meta)
META_APP_SECRET=

# ---- Google Calendar OAuth ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/google/callback

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_CLINIC=

# ---- Redis / BullMQ ----
REDIS_URL=redis://localhost:6379

# ---- Resend (transactional email) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=notificaciones@clientpilot.ai

# ---- Encryption (for OAuth token storage at rest) ----
TOKEN_ENCRYPTION_KEY=
