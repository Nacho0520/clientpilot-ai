# ===========================================================================
# ClientPilot AI — Variables de entorno
# ===========================================================================
# Copia este fichero como .env.local (desarrollo) o configura en Vercel/host
# (producción). Nunca commitees el fichero .env.local con valores reales.
#
# ORDEN RECOMENDADO DE CONFIGURACIÓN (de más a menos urgente):
# ──────────────────────────────────────────────────────────────
#  1. Supabase      → NEXT_PUBLIC_SUPABASE_*, SUPABASE_SERVICE_ROLE_KEY
#  2. Redis         → REDIS_URL (Railway Redis o Upstash)
#  3. Claves locales→ TOKEN_ENCRYPTION_KEY, CRON_SECRET
#  4. WhatsApp      → TWILIO_* o META_*
#  5. Google Cal    → GOOGLE_OAUTH_*
#  6. Resend        → RESEND_API_KEY, RESEND_FROM_EMAIL
#  7. Anthropic     → ANTHROPIC_API_KEY (requerido para el pipeline IA)
#  8. Sentry        → SENTRY_DSN (observabilidad; opcional pero muy recomendable)
#  9. PostHog       → NEXT_PUBLIC_POSTHOG_KEY, NEXT_PUBLIC_POSTHOG_HOST (analítica)
# 10. Stripe        → STRIPE_* (sólo cuando tengas cuenta legal; quitar BILLING_DISABLED)
#
# CHECKLIST DE PUESTA EN PRODUCCIÓN
# ──────────────────────────────────
# □ NEXT_PUBLIC_APP_URL apunta al dominio real (sin barra al final).
# □ Supabase: URL + anon key + service role key copiados desde el proyecto EU.
# □ Migraciones aplicadas: pnpm exec supabase db push
# □ Redis: REDIS_URL accesible desde el worker (Railway Redis o Upstash rediss://).
# □ Anthropic: API key válida; Claude Sonnet 4.5 disponible.
# □ WhatsApp (elegir una vía):
#     Twilio: Cuenta activa + número WhatsApp aprobado bajo esa cuenta.
#             Webhook POST {NEXT_PUBLIC_APP_URL}/api/twilio/webhook
#     Meta:   META_SYSTEM_USER_TOKEN con permisos whatsapp_business_messaging
#             META_APP_SECRET para validar firma X-Hub-Signature-256
#             META_VERIFY_TOKEN coincide con el configurado en Meta → Webhook
#             Webhook Meta POST {NEXT_PUBLIC_APP_URL}/api/meta/webhook
# □ Google:    OAuth consent screen publicado; redirect URI registrada:
#              {NEXT_PUBLIC_APP_URL}/api/google/callback
# □ Resend:    Dominio verificado en Resend; RESEND_FROM_EMAIL en ese dominio.
# □ TOKEN_ENCRYPTION_KEY: 32 bytes hex (openssl rand -hex 32).
# □ CRON_SECRET: cadena aleatoria larga; Vercel cron lo envía como Bearer token.
#               vercel.json ya configura el schedule de /api/cron/followups.
# □ Sentry: proyecto en sentry.io creado (región DE); DSN copiado.
#           NEXT_PUBLIC_SENTRY_DSN → Vercel (app) + SENTRY_DSN → Railway (worker).
# □ PostHog: proyecto EU creado; NEXT_PUBLIC_POSTHOG_KEY copiado.
# □ Worker arrancado en Railway: pnpm run worker
# □ BILLING_DISABLED=true mientras no haya cuenta Stripe (quitar cuando esté listo).
# ===========================================================================

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ---- Billing ----
# Pon BILLING_DISABLED=true mientras no tengas cuenta Stripe configurada.
# La UI mostrará un aviso, las rutas /api/stripe/* responderán 503.
BILLING_DISABLED=true
NEXT_PUBLIC_BILLING_DISABLED=true

# Vercel Cron: GET /api/cron/followups exige Authorization: Bearer <este valor>
CRON_SECRET=

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Anthropic ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- Twilio WhatsApp ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número Twilio sandbox de desarrollo: whatsapp:+14155238886
# En producción: el número aprobado para tu cuenta (formato whatsapp:+XXXXXXXXXXX)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ---- Meta Cloud API (alternativa recomendada a Twilio) ----
META_SYSTEM_USER_TOKEN=
# Token de verificación arbitrario; debe coincidir con el que pongas en Meta → Webhook
META_VERIFY_TOKEN=
# App Secret de Meta → firma X-Hub-Signature-256 en POST /api/meta/webhook (obligatorio en producción)
META_APP_SECRET=

# ---- Google Calendar OAuth ----
# Crea un proyecto en Google Cloud Console → API y servicios → Credenciales → OAuth 2.0
# El CLIENT_ID y CLIENT_SECRET son de la credencial de la PLATAFORMA (tuya como desarrollador).
# Cada cliente conecta su propio Google Calendar desde el dashboard; los tokens se guardan cifrados en Supabase.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/google/callback

# ---- Stripe (sólo cuando tengas cuenta legal; mientras tanto BILLING_DISABLED=true) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# IDs de los precios recurrentes en Stripe (lookup_key o price_XXXXXX)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_CLINIC=

# ---- Redis / BullMQ ----
# Upstash Redis en producción (TLS): REDIS_URL=rediss://:token@host:port
# Railway Redis: copia desde el plugin Redis → Variables → REDIS_URL
REDIS_URL=redis://localhost:6379

# ---- Resend (transactional email) ----
RESEND_API_KEY=
# Debe ser un remitente del dominio verificado en Resend
RESEND_FROM_EMAIL=notificaciones@clientpilot.ai

# ---- Encryption (tokens OAuth de Google se guardan cifrados en Supabase) ----
# Genera con: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ---- Sentry (observabilidad: errores y trazas) ----
# Crea un proyecto Next.js en sentry.io → Settings → Client Keys → DSN
# NEXT_PUBLIC_SENTRY_DSN → Vercel env (visible en el cliente browser)
# SENTRY_DSN             → Railway env (solo servidor / worker)
# Son el mismo valor; el prefijo NEXT_PUBLIC_ lo hace disponible en el cliente.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Para source maps en CI/Vercel build (opcional):
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# ---- PostHog (analítica de producto — región EU) ----
# Crea proyecto en app.posthog.com → EU cloud → Project settings → Project API Key
# Host EU: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
